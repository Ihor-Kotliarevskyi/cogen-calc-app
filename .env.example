# Optional explicit API endpoint for frontend. If empty, app tries /api/tariffs then Netlify function path.
VITE_TARIFFS_API_URL=

# Energy Map credentials (server-side only)
ENERGYMAP_API_KEY=
ENERGYMAP_GAS_UUID=
ENERGYMAP_RDN_UUID=
ENERGYMAP_GAS_VALUE_COLUMN=1
ENERGYMAP_RDN_VALUE_COLUMN=1
ENERGYMAP_RDN_FILTER_COLUMN=
ENERGYMAP_RDN_FILTER_VALUE=
ENERGYMAP_RDN_FILTER2_COLUMN=
ENERGYMAP_RDN_FILTER2_VALUE=
ENERGYMAP_HEAT_UUID=
ENERGYMAP_HEAT_VALUE_COLUMN=1
ENERGYMAP_HEAT_MANUAL_TARIFF=
ENERGYMAP_HEAT_FILTER_COLUMN=
ENERGYMAP_HEAT_FILTER_VALUE=
ENERGYMAP_HEAT_FILTER2_COLUMN=
ENERGYMAP_HEAT_FILTER2_VALUE=
ENERGYMAP_GREEN_TARIFF_UUID=
ENERGYMAP_GREEN_TARIFF_VALUE_COLUMN=1
ENERGYMAP_GREEN_TARIFF_FILTER_COLUMN=
ENERGYMAP_GREEN_TARIFF_FILTER_VALUE=
ENERGYMAP_GREEN_TARIFF_FILTER2_COLUMN=
ENERGYMAP_GREEN_TARIFF_FILTER2_VALUE=

# Sync policy
ENERGYMAP_AUTO_SYNC=false
ENERGYMAP_CACHE_TTL_HOURS=24
# Recommended with scheduled refresh: keep false, scheduled job will force sync

# Optional admin token for forced refresh (?refresh=1 with header x-sync-token)
TARIFFS_SYNC_TOKEN=

